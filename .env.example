LAMBDA_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
ORCA_API_KEY=your-server-side-orca-api-key

# Optional: local dev fallback when running `npm run dev`
VITE_LAMBDA_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
VITE_ORCA_API_KEY=your-local-dev-orca-api-key

# Optional: override frontend endpoint (default is /api/chat)
VITE_API_ENDPOINT=/api/chat
